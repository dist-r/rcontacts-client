@page "/signup"
@layout AuthLayout
@inject AuthState Auth
@implements IDisposable

<PageTitle>Sign Up — RContacts</PageTitle>

<div class="auth-page">
    <div class="auth-bg-blur auth-blur-1"></div>
    <div class="auth-bg-blur auth-blur-2"></div>

    <div class="auth-card" style="max-width: 440px;">
        <!-- Logo Header -->
        <div class="auth-logo">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="color: #a78bfa; font-size: 48px;" />
        </div>
        <div class="auth-header">
            <h1 class="auth-title">Create Account</h1>
            <p class="auth-subtitle">Join RContacts and manage your network</p>
        </div>

        <div class="auth-form">
            @if (Auth.RegisterError is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@Auth.RegisterError</MudAlert>
            }

            <MudTextField @bind-Value="_username"
                          Label="Username"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                          AdornmentColor="Color.Primary"
                          Class="auth-field"
                          Placeholder="Choose a username"
                          Required="true" />

            <MudTextField @bind-Value="_name"
                          Label="Full Name"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          Class="auth-field"
                          Placeholder="Enter your full name"
                          Required="true" />

            <MudTextField @bind-Value="_email"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          AdornmentColor="Color.Primary"
                          Class="auth-field"
                          Placeholder="Enter your email"
                          Required="true" />

            <MudTextField @bind-Value="_password"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="@_passwordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          AdornmentColor="Color.Primary"
                          Class="auth-field"
                          Placeholder="Create a password"
                          Required="true" />

            <MudTextField @bind-Value="_confirmPassword"
                          Label="Confirm Password"
                          Variant="Variant.Outlined"
                          InputType="@_passwordInputType"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          AdornmentColor="Color.Primary"
                          Class="auth-field"
                          Placeholder="Confirm your password"
                          Required="true" />

            <MudDialog @bind-Visible="_isPasswordMismatchOpen" Options="_dialogOptions">
                <TitleContent>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Style="color: #f59e0b;" />
                        <span>Password Mismatch</span>
                    </div>
                </TitleContent>
                <DialogContent>
                    <p style="margin: 0; color: rgba(255,255,255,0.75);">
                        Password and confirm password must be the same.
                    </p>
                </DialogContent>
                <DialogActions>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="ClosePasswordMismatchPopup">
                        OK
                    </MudButton>
                </DialogActions>
            </MudDialog>

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleRegister"
                       Disabled="Auth.IsRegistering"
                       StartIcon="@Icons.Material.Filled.HowToReg"
                       Style="background: linear-gradient(135deg, #7c3aed, #4f46e5); color: white; height: 52px; font-weight: 700; font-size: 16px; border-radius: 12px; margin-top: 8px;">
                @if (Auth.IsRegistering)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color: white; margin-right: 8px;" />
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Create Account</span>
                }
            </MudButton>
        </div>

        <div class="auth-footer-text">
            Already have an account?
            <MudLink Href="/signin" Style="color: #a78bfa; font-weight: 600;">Sign In</MudLink>
        </div>

        <div class="auth-back-link">
            <MudLink Href="/" Style="color: rgba(255,255,255,0.4); font-size: 13px;">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Style="font-size: 14px; vertical-align: middle;" />
                Back to Home
            </MudLink>
        </div>
    </div>
</div>

@code {
    private string _username = string.Empty;
    private string _name = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showPassword = false;
    private bool _isPasswordMismatchOpen = false;
    private readonly DialogOptions _dialogOptions = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true
    };

    private InputType _passwordInputType => _showPassword ? InputType.Text : InputType.Password;
    private string _passwordIcon => _showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    protected override void OnInitialized()
    {
        Auth.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Auth.OnChange -= StateHasChanged;
    }

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(_username) ||
            string.IsNullOrWhiteSpace(_name) ||
            string.IsNullOrWhiteSpace(_email) ||
            string.IsNullOrWhiteSpace(_password)) return;

        if (_password != _confirmPassword)
        {
            _isPasswordMismatchOpen = true;
            return;
        }


        await Auth.Register(_username, _name, _email, _password);
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ClosePasswordMismatchPopup()
    {
        _isPasswordMismatchOpen = false;
    }
}
